// secrets.h.example — 複製成 secrets.h 後填入你的真實值
// 真檔 secrets.h 已被 .gitignore 擋住,不會進 git history
//
// 步驟:
//   1. 把這個檔案複製改名為 secrets.h(同目錄)
//   2. 填入你的 WiFi SSID / 密碼
//   3. 去 https://console.groq.com → API Keys → Create key,貼進 GROQ_API_KEY
//   4. 編譯 Mode10_Test

#ifndef SECRETS_H
#define SECRETS_H

#define WIFI_SSID       "your_wifi_ssid_here"
#define WIFI_PASS       "your_wifi_password_here"

// Groq API key,gsk_xxxxxx... 開頭的那串
#define GROQ_API_KEY    "gsk_your_groq_api_key_here"

#endif
