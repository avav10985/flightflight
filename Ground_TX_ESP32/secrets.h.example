// secrets.h.example — 複製成 secrets.h 後填入你的真實值
// 真檔 secrets.h 已被 .gitignore 擋住,不會進 git history
//
// 步驟:
//   1. 把這個檔案複製改名為 secrets.h(同目錄)
//   2. 填入 WiFi SSID / 密碼
//   3. Groq key:https://console.groq.com → API Keys(語音辨識 Whisper 用)
//   4. Gemini key:https://aistudio.google.com → Get API Key(指令解析用)
//   5. 編譯 Mode10_Test

#ifndef SECRETS_H
#define SECRETS_H

#define WIFI_SSID         "your_wifi_ssid_here"
#define WIFI_PASS         "your_wifi_password_here"

// Groq API key(語音 → 文字,Whisper),gsk_xxxxxx... 開頭
#define GROQ_API_KEY      "gsk_your_groq_api_key_here"

// Google Gemini API key(文字 → 指令 JSON),AIzaSy... 開頭
#define GEMINI_API_KEY    "AIzaSy_your_gemini_api_key_here"

#endif
