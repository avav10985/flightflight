// secrets.h.example - 範本,複製成 secrets.h 後再改成你的真實 WiFi 帳密
// 真正的 secrets.h 在 .gitignore 內,不會進 git history
//
// 使用方式:
//   1. 複製這個檔案改名為 secrets.h(同目錄)
//   2. 把 dummy 換成你的熱點 SSID + 密碼
//   3. 編譯 ESP32CAM_Flight
//
// 注意:FORCE_AP_MODE = 1 時這兩個值不會被讀(CAM 直接開 AP「DroneCAM」),
//      隨便填 dummy 也能編譯通過。要用 STA 模式才要填對。

#ifndef SECRETS_H
#define SECRETS_H

#define WIFI_SSID_VAL "your_wifi_ssid_here"
#define WIFI_PASS_VAL "your_wifi_password_here"

#endif
